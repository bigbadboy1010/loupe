# Use one long random secret for both signaling and coturn.
# Example generation:
#   openssl rand -base64 48
TURN_SECRET=replace-with-at-least-32-random-characters

# Public DNS name or IP clients can reach for STUN/TURN.
TURN_HOST=turn.example.com
TURN_REALM=loupe.local

# Required only when coturn is behind NAT.
# TURN_EXTERNAL_IP=203.0.113.10

# Set to true to also serve the marketing site (/) and waitlist endpoint (POST /waitlist).
# Disable if you want to front the landing page elsewhere (Netlify / Cloudflare Pages) and
# keep this container focused on signaling + TURN.
SERVE_SITE=false
